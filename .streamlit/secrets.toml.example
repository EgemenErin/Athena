# Copy to secrets.toml for local dev, or paste into Streamlit Community Cloud
# (App → Settings → Secrets). Top-level keys are exposed as environment variables.

# Remote Ollama server (required on Community Cloud — no local Ollama there).
# Example: a VPS or tunnel exposing Ollama on port 11434.
OLLAMA_HOST = "https://your-ollama-host.example.com"

# Must match a model pulled on that server.
OLLAMA_MODEL = "qwen2.5-coder:7b"
